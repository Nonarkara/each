# Phase 0 — OAuth (client IDs only; secrets stay on Cloudflare dashboard)
VITE_GOOGLE_CLIENT_ID=
VITE_GITHUB_CLIENT_ID=
# GitHub OAuth redirect — must match GitHub App settings
# Example: https://each.nonarkara.org/oauth/github/callback
VITE_GITHUB_REDIRECT_URI=
# Optional override if token exchange runs on a different host
VITE_GITHUB_TOKEN_EXCHANGE_URL=

# Gmail receipt import (separate from sign-in client)
VITE_GOOGLE_REDIRECT_URI=

# Phase 1 — optional live integrations
VITE_COMPANY_LOOKUP_API=
VITE_OCR_API_URL=

# Google Sheets two-way sync (Apps Script Web App URL)
VITE_SHEETS_WEB_APP_URL=

# Phase 2 — Frappe REST backend
VITE_FRAPPE_URL=

# Cloudflare Pages Function secrets (set in dashboard — NOT in .env)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
